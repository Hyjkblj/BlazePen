{
  "name": "no-end-story",
  "productName": "No End Story",
  "version": "1.0.0",
  "description": "基于 OpenAI 的无限剧情流游戏",
  "author": "No End Story Team",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:story",
    "dev:story": "vite --mode story --config vite.story.config.ts",
    "dev:training": "vite --mode training --config vite.training.config.ts",
    "dev:all": "concurrently \"npm run dev:story\" \"npm run dev:training\"",
    "build": "npm run build:story",
    "build:story": "tsc -b && vite build --mode story --config vite.story.config.ts",
    "build:training": "tsc -b && vite build --mode training --config vite.training.config.ts",
    "build:all": "npm run build:story && npm run build:training",
    "lint": "eslint .",
    "test:smoke": "npm run test:smoke:story",
    "test:smoke:story": "vitest run src/pages/MainPathSmoke.integration.test.tsx",
    "test:smoke:training": "vitest run src/pages/TrainingMainPathSmoke.integration.test.tsx",
    "test:smoke:training:insights": "vitest run src/pages/TrainingInsights.integration.test.tsx",
    "test:training:route-integration": "vitest run src/pages/Training.integration.test.tsx",
    "test:boundary:training:legacy-briefing": "vitest run src/test/trainingLegacyBriefingBoundary.test.ts",
    "test:smoke:training:all": "npm run test:smoke:training && npm run test:smoke:training:insights && npm run test:boundary:training:legacy-briefing",
    "test:smoke:all": "npm run test:smoke:story && npm run test:smoke:training:all",
    "test:unit": "vitest run",
    "test:electron": "node --test tests/electron/navigationPolicy.test.mjs",
    "preview": "vite preview --mode story --config vite.story.config.ts",
    "preview:training": "vite preview --mode training --config vite.training.config.ts",
    "electron:dev": "concurrently \"npm run dev:story\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder --publish=never"
  },
  "dependencies": {
    "antd": "^6.3.3",
    "axios": "^1.13.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.noendstory.app",
    "productName": "No End Story",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
