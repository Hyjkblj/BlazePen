# ============================================
# Environment
# ============================================
# Options: dev, prod, test
ENV=dev

# ============================================
# Backend Entrypoints
# ============================================
# STORY_API_HOST=0.0.0.0
# STORY_API_PORT=8000
# STORY_API_RELOAD=true
# TRAINING_API_HOST=0.0.0.0
# TRAINING_API_PORT=8010
# TRAINING_API_RELOAD=false

# ============================================
# Database
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noendstory
DB_USER=postgres
DB_PASSWORD=

# ============================================
# Vector / Embedding
# ============================================
# VECTOR_DB_PATH=
# Options: default, text2vec-chinese, m3e-base, bge-small-zh-v1.5, paraphrase-multilingual
EMBEDDING_MODEL=text2vec-chinese

# ============================================
# AI Provider Keys
# ============================================
OPENAI_API_KEY=

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-flash
DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

ZHIPU_API_KEY=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ============================================
# Volcengine (recommended)
# ============================================
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_IMAGE_ARK_API_KEY=
ARK_API_KEY=
VOLCENGINE_REGION=cn-beijing

# Unified text model switch (preferred)
LLM_TEXT_MODEL=deepseek-r1-250528
# Legacy key kept for backward compatibility
VOLCENGINE_TEXT_MODEL=

VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_IMAGE_SIZE=2K

# TTS
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_SECRET_KEY=
VOLCENGINE_TTS_MODEL=seed-tts-2.0
VOLCENGINE_TTS_RESOURCE_ID=volc.tts.default

# Optional WebSocket TTS
VOLCENGINE_TTS_WEBSOCKET_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
VOLCENGINE_TTS_USE_WEBSOCKET=false

# TTS feature flags
VOLCENGINE_TTS_ENABLE_TIMESTAMP=false
VOLCENGINE_TTS_ENABLE_CACHE=true
VOLCENGINE_TTS_ENABLE_EMOTION=true

# ============================================
# TTS Provider
# ============================================
# Options: volcengine, dashscope, edge-tts
TTS_PROVIDER=volcengine

# ============================================
# Optional local model (Ollama)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen:7b

# ============================================
# Optional game tuning
# ============================================
# GAME_MAX_EVENTS=3
# GAME_TOTAL_EVENTS=5

# ============================================
# Training (P2 evaluation)
# ============================================
# Enable LLM-based evaluation for training rounds
TRAINING_USE_LLM_EVAL=false
# Enforce submit_round scenario to match current expected scenario
TRAINING_ENFORCE_SCENARIO_ORDER=true

# Training evaluator provider/model
TRAINING_LLM_PROVIDER=auto
TRAINING_EVAL_MODEL=

# Training evaluator generation controls
TRAINING_LLM_MAX_TOKENS=700
TRAINING_LLM_TEMPERATURE=0.2
TRAINING_LLM_MAX_RETRIES=2
TRAINING_LLM_RETRY_DELAY=0.8

# Training media task executor timeouts (seconds)
# Scene-series generation (major + micro scenes) is slower than simple image tasks.
TRAINING_MEDIA_TASK_TIMEOUT_SECONDS=30
TRAINING_MEDIA_SCENE_TASK_TIMEOUT_SECONDS=120

# LLM/rules fusion weights (auto-normalized internally)
TRAINING_EVAL_LLM_WEIGHT=0.70
TRAINING_EVAL_RULE_WEIGHT=0.30

# Per-round delta guardrails
TRAINING_MAX_SKILL_DELTA=0.20
TRAINING_MAX_S_DELTA=0.20

# ============================================
# Image output
# ============================================
IMAGE_SAVE_DIR=./images/characters
SCENE_IMAGE_SAVE_DIR=./images/scenes
SMALL_SCENE_IMAGE_SAVE_DIR=./images/smallscenes
COMPOSITE_IMAGE_SAVE_DIR=./images/composite
IMAGE_SAVE_ENABLED=true

# ============================================
# CORS (required in production)
# ============================================
# Shared fallback for both backends:
# ALLOWED_ORIGINS=https://example.com,https://www.example.com
#
# Or explicit per-backend allowlists:
# STORY_ALLOWED_ORIGINS=https://story.example.com
# TRAINING_ALLOWED_ORIGINS=https://training.example.com

# ============================================
# Logging
# ============================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
